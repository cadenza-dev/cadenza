{
  "config": {
    "default": true,
    "line-length": false
  },
  "globs": ["**/*.md"],
  "ignores": [
    "node_modules",
    ".claude/skills",
    "skills/*-workspace/**/outputs/**",
    "skills/*-workspace/**/transcript.md"
  ],
  "fix": true,
  "outputFormatters": [["markdownlint-cli2-formatter-pretty"]]
}
