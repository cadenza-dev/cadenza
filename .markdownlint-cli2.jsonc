{
    "config": {
        "default": true,
        "line-length": false
    },
    "globs": [
        "**/*.md"
    ],
    "ignores": [
        "node_modules",
        "CHANGELOG.md"
    ],
    "fix": false,
    "outputFormatters": [
        [
            "markdownlint-cli2-formatter-pretty"
        ]
    ]
}