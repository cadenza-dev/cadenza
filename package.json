{
  "name": "cadenza",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "prepare": "bash scripts/install-git-hooks.sh",
    "build:browser-fixture": "esbuild tests/browser/cadenza-browser-entry.ts --bundle --format=iife --global-name=CadenzaBrowserFixtureBundle --outfile=tmp/cadenza-browser-fixture.js",
    "cadenza": "node --experimental-strip-types scripts/cadenza.ts",
    "preview:phase4": "node examples/phase4/serve-preview.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:browser": "pnpm build:browser-fixture && playwright test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "format:md": "markdownlint-cli2 --fix \"**/*.md\"",
    "lint:shell": "find scripts .agents .githooks .codex -name '*.sh' -print0 | xargs -0 shfmt -d",
    "format:shell": "find scripts .agents .githooks .codex -name '*.sh' -exec shfmt -w {} +",
    "spec:lint": "node --experimental-strip-types scripts/lint-specs.ts",
    "phase:check": "node --experimental-strip-types scripts/phase-check.ts",
    "check:harness": "node --experimental-strip-types scripts/check-harness.ts",
    "check:memory": "node --experimental-strip-types scripts/check-memory.ts",
    "check:frozen": "node --experimental-strip-types scripts/check-contract-frozen.ts",
    "check:role-boundary": "node --experimental-strip-types scripts/check-role-boundary.ts",
    "ci:classify": "node --experimental-strip-types scripts/classify-ci-changes.ts",
    "precommit": "bash scripts/pre-commit.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "markdownlint-cli2": "^0.22.1",
    "markdownlint-cli2-formatter-pretty": "^0.0.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
