{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash scripts/hooks/session-brief.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash scripts/hooks/enforce-architect-boundary.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash scripts/hooks/block-dangerous-bash.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash scripts/hooks/post-format-edit.sh" },
          { "type": "command", "command": "bash scripts/hooks/post-spec-edit.sh" },
          { "type": "command", "command": "bash scripts/hooks/rebuild-adr-index.sh" },
          { "type": "command", "command": "bash scripts/hooks/post-md-edit.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash scripts/hooks/session-stop-audit.sh" }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "bash scripts/hooks/pre-compact-preserve.sh" }
        ]
      }
    ]
  }
}
